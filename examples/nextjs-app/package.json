{
  "name": "@examples/nextjs-app",
  "version": "0.1.124",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "cross-env TSCONFIG=./tsconfig.no-paths.json next build",
    "start": "next start",
    "clean": "rimraf ./.next ./coverage ./tsconfig.tsbuildinfo",
    "test": "vitest run",
    "test-unit": "vitest run",
    "test-unit-watch": "vitest --ui",
    "typegen": "next typegen",
    "typecheck": "next typegen && tsc --project tsconfig.json --noEmit",
    "typecheck-no-paths": "next typegen && tsc --project tsconfig.no-paths.json --noEmit",
    "lint": "next typegen && eslint . --ext .ts,.tsx,.js,.jsx,.mjs,.cjs,.mts,.cts --cache --cache-location ../../.cache/eslint/nextjs-app.eslintcache",
    "fix-staged": "lint-staged --allow-empty"
  },
  "dependencies": {
    "@hono/node-server": "1.19.14",
    "@httpx/assert": "workspace:^",
    "@httpx/compress": "workspace:^",
    "@httpx/dsn-parser": "workspace:^",
    "@httpx/encode": "workspace:^",
    "@httpx/exception": "workspace:^",
    "@httpx/lru": "workspace:^",
    "@httpx/memo-intl": "workspace:^",
    "@httpx/plain-object": "workspace:^",
    "@httpx/stable-hash": "workspace:^",
    "@httpx/treeu": "workspace:^",
    "@httpx/xcache": "workspace:^",
    "axios": "1.15.0",
    "clsx": "2.1.1",
    "hono": "4.12.14",
    "ky": "2.0.1",
    "next": "16.2.4",
    "pino": "10.3.1",
    "primereact": "10.9.7",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "superjson": "2.2.6",
    "tailwind-merge": "3.5.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@belgattitude/eslint-config-bases": "8.13.0",
    "@tailwindcss/postcss": "4.2.2",
    "@types/node": "25.6.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react-swc": "4.3.0",
    "@vitest/coverage-v8": "4.1.4",
    "@vitest/ui": "4.1.4",
    "cross-env": "10.1.0",
    "eslint": "8.57.1",
    "happy-dom": "20.9.0",
    "postcss": "8.5.10",
    "prettier": "3.8.3",
    "rimraf": "6.1.3",
    "tailwindcss": "4.2.2",
    "typescript": "6.0.2",
    "vite": "8.0.8",
    "vite-plugin-svgr": "5.2.0",
    "vitest": "4.1.4",
    "webpack": "5.106.2"
  }
}
