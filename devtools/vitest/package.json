{
  "name": "@httpx/devtools-vitest",
  "description": "Shareable dev setups for vitest",
  "version": "0.0.2",
  "private": true,
  "type": "module",
  "license": "MIT",
  "author": {
    "name": "Vanvelthem Sébastien",
    "url": "https://github.com/belgattitude"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/belgattitude/httpx.git",
    "directory": "devtools/vitest"
  },
  "sideEffects": false,
  "exports": {
    ".": "./src/index.ts",
    "./package.json": "./package.json",
    "./wrangler.toml": "./wrangler.toml"
  },
  "scripts": {
    "clean": "rimraf ./dist ./build ./coverage ./_release",
    "build": "tsdown",
    "fix-staged": "lint-staged --allow-empty",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx,.mjs,.cjs,.mts,.cts",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "install-playwright": "playwright install chromium"
  },
  "dependencies": {
    "@belgattitude/eslint-config-bases": "8.13.0",
    "@cloudflare/vitest-pool-workers": "0.14.7",
    "@codspeed/vitest-plugin": "5.2.0",
    "@edge-runtime/vm": "5.0.0",
    "@testing-library/dom": "10.4.1",
    "@types/estree": "1.0.8",
    "@vitest/browser": "4.1.4",
    "@vitest/browser-playwright": "4.1.4",
    "@vitest/coverage-istanbul": "4.1.4",
    "@vitest/runner": "4.1.4",
    "@vitest/snapshot": "4.1.4",
    "@vitest/ui": "4.1.4",
    "ci-info": "4.4.0",
    "esbuild": "0.28.0",
    "eslint": "8.57.1",
    "is-ci": "4.1.0",
    "playwright": "1.59.1",
    "prettier": "3.8.3",
    "rollup": "4.60.2",
    "tinybench": "6.0.0",
    "type-fest": "5.5.0",
    "typescript": "6.0.3",
    "vite": "8.0.8",
    "vitest": "4.1.4",
    "vitest-browser-react": "2.2.0"
  },
  "devDependencies": {
    "@types/node": "25.6.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "baseline-browser-mapping": "2.10.19",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "tsdown": "0.21.9",
    "vitest": "4.1.4"
  },
  "engines": {
    "node": ">=20"
  }
}
